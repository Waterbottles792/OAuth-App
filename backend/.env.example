# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# Used in Phase 1+ for user accounts, sessions, etc.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oauth_platform
DB_USER=oauth_user
DB_PASSWORD=oauth_dev_password_change_in_production
DB_SSL=false

# ============================================
# REDIS CONFIGURATION
# ============================================
# Used in Phase 1+ for session storage and rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password_change_in_production

# ============================================
# SECURITY CONFIGURATION
# ============================================
# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Rate Limiting (Phase 1+)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Security (Phase 1+)
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars
SESSION_COOKIE_MAX_AGE=86400000

# ============================================
# OAUTH / TOKENS (Phase 3+/4+)
# ============================================
# Where /authorize sends unauthenticated users to log in (frontend)
LOGIN_URL=http://localhost:3000/login
# JWT issuer identity (the `iss` claim). Must be stable; resource servers verify it.
ISSUER_URL=http://localhost:3001
# Default audience (`aud`) for access tokens
ACCESS_TOKEN_AUDIENCE=oauth-platform-api
# Secret used to derive the AES-256-GCM key that encrypts JWT private keys at rest.
# REQUIRED (>=32 chars) in production.
JWT_KEY_ENCRYPTION_SECRET=change-me-in-production-min-32-characters-long

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

# ============================================
# PHASE-SPECIFIC NOTES
# ============================================
# Phase 0: Only server configuration is active
# Phase 1+: Database, Redis, and security configs will be used
# Phase 4+: JWT signing keys will be added
# Phase 6+: OIDC-specific configuration will be added
