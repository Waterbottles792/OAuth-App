# ============================================
# BACKEND API CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_VERSION=v1

# ============================================
# OAUTH CONFIGURATION (Phase 7+)
# ============================================
# These will be used when implementing login and consent UI
# NEXT_PUBLIC_OAUTH_AUTHORIZE_URL=http://localhost:3001/api/v1/oauth/authorize
# NEXT_PUBLIC_OAUTH_CLIENT_ID=frontend-client

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_NAME=OAuth Platform
NEXT_PUBLIC_APP_ENVIRONMENT=development

# ============================================
# SECURITY NOTES
# ============================================
# - NEVER store tokens in localStorage or sessionStorage
# - All authentication state must use HTTP-only cookies
# - No sensitive data should be exposed via NEXT_PUBLIC_ variables
